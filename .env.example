# Copy to `.env` (or set in docker-compose.yml). All values have sane defaults.

# --- server ---
PORT=3000
FRONTEND_DIR=                       # static UI dir; default ../frontend (local), /frontend (Docker)

# --- primary store (SQLite) ---
DB_PATH=                            # default backend/data/typeahead.db (local), /data/... (Docker)

# --- dataset ingestion ---
DATASET_PATH=                       # TSV "<query>\t<count>"; if absent, synthetic data is generated

# --- distributed cache (consistent hashing over N Redis nodes) ---
REDIS_NODES=localhost:6379,localhost:6380,localhost:6381   # Docker: redis-0:6379,redis-1:6379,redis-2:6379
CACHE_TTL_SECONDS=60                 # TTL for popular-ranked suggestion cache
CACHE_TTL_TRENDING_SECONDS=10        # shorter TTL for fast-changing trending cache

# --- trending (recency-aware ranking) ---
RECENCY_ALPHA=0.5                    # blend weight: 0 = pure popularity, 1 = pure recency
TREND_BUCKET_MS=30000                # sliding-window bucket size
TREND_WINDOW_BUCKETS=10              # number of buckets in the window (window = bucket * count)

# --- batch writes ---
BATCH_INTERVAL_MS=2000               # flush the search buffer at least this often
BATCH_MAX_SIZE=500                   # ...or when this many distinct queries are buffered
